@model DiscountViewModel
@{
	ViewData["Title"] = "UpdateDiscount";
	Layout = "~/Views/AdminLayout/Index.cshtml";
}
<div class="content">
	<div class="container-fluid">
		<h4 class="page-title">İndirimleri Ürün İşlemleri</h4>
		<div class="row">
			<div class="col-md-12">
				<form asp-action="UpdateDiscount" asp-route-id="@Model.DiscountID" method="post">
					<div class="card">
						<div class="card-header">
							<div class="card-title">İndirimli Ürün Bilgisi Güncelleme</div>
						</div>
						<div class="card-body">
							<div class="form-group">
								<Label for="Title">Ürün Adını Giriniz</label>
								<input type="text" class="form-control" asp-for="Title">
								<span asp-validation-for="Title" class="text-danger"></span>
							</div>
							<div class="form-group">
								<Label for="Amount">Ürün İndirim Oranını Giriniz</label>
								<input type="number" class="form-control" asp-for="Amount">
								<span asp-validation-for="Amount" class="text-danger"></span>
							</div>
							<div class="form-group">
								<Label for="ImageUrl">Ürün Görselini Giriniz</label>
								<input type="text" class="form-control" asp-for="ImageUrl">
								<span asp-validation-for="ImageUrl" class="text-danger"></span>
							</div>
							<div class="form-group">
								<Label for="Description">Ürün Açıklamasını Giriniz</label>
								<textarea rows="5" class="form-control" asp-for="Description"></textarea>
								<span asp-validation-for="Description" class="text-danger"></span>
							</div>
						</div>
						<div class="card-action">
							<button type="submit" class="btn btn-primary">İndirimli Ürün Bilgisini Güncelle</button>
						</div>
					</div>
				</form>
			</div>
		</div>
	</div>
</div>