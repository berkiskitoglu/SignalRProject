@model CreateMailDto

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}


<div class="content">
	<div class="container-fluid">
		<h4 class="page-title">Mail Ayarları</h4>
		<div class="row">
			<div class="col-md-12">
				<form method="post">
					<div class="card">
						<div class="card-header">
							<div class="card-title">Mail Gönderme Sayfası</div>
						</div>
						<div class="card-body">
							<div class="form-group">
								<label for="ReceiverMail">Alıcı Mail Adresi</label>
								<input type="text" class="form-control" asp-for="ReceiverMail">
							</div>
							<div class="form-group">
								<label for="Subject">Konu</label>
								<input type="text" class="form-control" asp-for="Subject">
							</div>
							<div class="form-group">
								<label for="Content">Mesajınız</label>
								<textarea class="form-control" asp-for="Content" rows="5" id="Content"></textarea>
							</div>
						
						</div>
						<div class="card-action">
							<button type="submit" class="btn btn-success">Maili Gönder</button>
						</div>
					</div>
				</form>
			</div>
		</div>
	</div>
</div>


