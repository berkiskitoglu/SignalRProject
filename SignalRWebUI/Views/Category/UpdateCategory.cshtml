@model CategoryViewModel
@{
	ViewData["Title"] = "UpdateCategory";
	Layout = "~/Views/AdminLayout/Index.cshtml";
}
<div class="content">
	<div class="container-fluid">
		<h4 class="page-title">Kategori İşlemleri</h4>
		<div class="row">
			<div class="col-md-12">
				<form method="post" asp-action="UpdateCategory" asp-route-id="@Model.CategoryID">
					<div class="card">
						<div class="card-header">
							<div class="card-title">Kategori Güncelleme Sayfası</div>
						</div>
						<div class="card-body">
							<div class="form-group">
								<label asp-for="CategoryName">Kategori Adını Giriniz</label>
								<input type="text" class="form-control" placeholder="Kategori Adı Giriniz" asp-for="CategoryName">
								<span asp-validation-for="CategoryName" class="text-danger"></span>
							</div>
						</div>
						<div class="card-action">
							<button type="submit" class="btn btn-primary">Kategoriyi Güncelle</button>
						</div>
					</div>
				</form>
			</div>
		</div>
	</div>
</div>