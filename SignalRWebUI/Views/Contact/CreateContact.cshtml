@model ContactViewModel
@{
	ViewData["Title"] = "CreateContact";
	Layout = "~/Views/AdminLayout/Index.cshtml";
}
<div class="content">
	<div class="container-fluid">
		<h4 class="page-title">Ana Sayfa İletişim İşlemleri</h4>
		<div class="row">
			<div class="col-md-12">
				<form asp-action="CreateContact" method="post">
					<div class="card">
						<div class="card-header">
							<div class="card-title">Yeni İletişim Bilgisi Girişi</div>
						</div>
						<div class="card-body">
							<div class="form-group">
								<label asp-for="Location">Lokasyon Giriniz</label>
								<input type="text" class="form-control" asp-for="Location">
								<span asp-validation-for="Location" class="text-danger"></span>
							</div>
							<div class="form-group">
								<label asp-for="Phone">Telefon Numarası Giriniz</label>
								<input type="tel" class="form-control" asp-for="Phone">
								<span asp-validation-for="Phone" class="text-danger"></span>
							</div>
							<div class="form-group">
								<label asp-for="Mail">Mail Adresi Giriniz</label>
								<input type="email" class="form-control" asp-for="Mail">
								<span asp-validation-for="Mail" class="text-danger"></span>
							</div>
							<div class="form-group">
								<label asp-for="FooterTitle">Alt Başlık Giriniz</label>
								<input type="text" class="form-control" asp-for="FooterTitle">
								<span asp-validation-for="FooterTitle" class="text-danger"></span>
							</div>
							<div class="form-group">
								<label asp-for="OpenDays">Açık Olduğumuz Günler</label>
								<input type="text" class="form-control" asp-for="OpenDays">
								<span asp-validation-for="OpenDays" class="text-danger"></span>
							</div>
							<div class="form-group">
								<label asp-for="OpenDaysDescription">Açık Olduğumuz Günlerin Açıklaması</label>
								<input type="text" class="form-control" asp-for="OpenDaysDescription">
								<span asp-validation-for="OpenDaysDescription" class="text-danger"></span>
							</div>
							<div class="form-group">
								<label asp-for="OpenHours">Açık Olduğumuz Saatler</label>
								<input type="text" class="form-control" asp-for="OpenHours">
								<span asp-validation-for="OpenHours" class="text-danger"></span>
							</div>
							<div class="form-group">
								<label asp-for="FooterDescription">Açıklama Giriniz</label>
								<textarea rows="5" class="form-control" asp-for="FooterDescription"></textarea>
								<span asp-validation-for="FooterDescription" class="text-danger"></span>
							</div>
						</div>
						<div class="card-action">
							<button type="submit" class="btn btn-primary">İletişim Bilgisi Ekle</button>
						</div>
					</div>
				</form>
			</div>
		</div>
	</div>
</div>