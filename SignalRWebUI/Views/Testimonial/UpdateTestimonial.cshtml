@model UpdateTestimonialViewModel
@{
	ViewData["Title"] = "UpdateTestimonial";
	Layout = "~/Views/AdminLayout/Index.cshtml";
}
<div class="content">
	<div class="container-fluid">
		<h4 class="page-title">Referans İşlemleri</h4>
		<div class="row">
			<div class="col-md-12">
				<form asp-action="UpdateTestimonial" asp-route-id="@Model.TestimonialID" method="post">
					<div class="card">
						<div class="card-header">
							<div class="card-title">Yorum Güncelleme İşlemi</div>
						</div>
						<div class="card-body">
							<div class="form-group">
								<Label for="Name">Müşteri Adını Giriniz</label>
								<input type="text" class="form-control" asp-for="Name">
								<span asp-validation-for="Name" class="text-danger"></span>
							</div>
							<div class="form-group">
								<Label for="Title">Müşteri Ünvanını Giriniz</label>
								<input type="text" class="form-control" asp-for="Title">
								<span asp-validation-for="Title" class="text-danger"></span>
							</div>
							<div class="form-group">
								<Label for="ImageUrl">Müşteri Resim Dosya Yolunu Giriniz</label>
								<input type="text" class="form-control" asp-for="ImageUrl">
								<span asp-validation-for="ImageUrl" class="text-danger"></span>
							</div>
							<div class="form-group">
								<Label for="Comment">Müşteri Yorumunu Giriniz</label>
								<textarea rows="5" class="form-control" asp-for="Comment"></textarea>
								<span asp-validation-for="Comment" class="text-danger"></span>
							</div>
						</div>
						<div class="card-action">
							<button type="submit" class="btn btn-primary">Yorumu Güncelle</button>
						</div>
					</div>
				</form>
			</div>
		</div>
	</div>
</div>