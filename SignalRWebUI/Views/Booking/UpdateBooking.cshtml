@model UpdateBookingDto
@{
	ViewData["Title"] = "UpdateBooking";
	Layout = "~/Views/AdminLayout/Index.cshtml";
}
<div class="content">
	<div class="container-fluid">
		<h4 class="page-title">Rezervasyon Güncelleme İşlemleri</h4>
		<div class="row">
			<div class="col-md-12">
				<form asp-action="UpdateBooking" asp-route-id="@Model.BookingID" method="post">
					<div class="card">
						<div class="card-header">
							<div class="card-title">Rezervasyon Güncelle</div>
						</div>
						<div class="card-body">
							<div class="form-group">
								<Label for="Name">Ad Soyad</label>
								<input type="text" class="form-control" asp-for="Name">
								<span asp-validation-for="Name" class="text-danger"></span>
							</div>
							<div class="form-group">
								<Label for="Phone">Telefon</label>
								<input type="tel" class="form-control" asp-for="Phone">
								<span asp-validation-for="Phone" class="text-danger"></span>
							</div>
							<div class="form-group">
								<Label for="Mail">Mail</label>
								<input type="email" class="form-control" asp-for="Mail">
								<span asp-validation-for="Mail" class="text-danger"></span>
							</div>
							<div class="form-group">
								<Label for="PersonCount">Kişi Sayısı</label>
								<input type="number" class="form-control" asp-for="PersonCount">
								<span asp-validation-for="PersonCount" class="text-danger"></span>
							</div>
							<div class="form-group">
								<Label for="Date">Rezervasyon Tarihi</label>
								<input type="date" class="form-control" asp-for="Date">
								<span asp-validation-for="Date" class="text-danger"></span>
							</div>
						</div>
						<div class="card-action">
							<button type="submit" class="btn btn-primary">Rezervasyonu Güncelle</button>
						</div>
					</div>
				</form>
			</div>
		</div>
	</div>
</div>