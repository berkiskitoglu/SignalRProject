@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<script src="~/js/signalr-progress.js"></script>

<div class="content">
    <div class="container-fluid">

        <h4 class="page-title">Admin İstatistikler & Durumlar</h4>

        <div class="row">

            <div class="col-md-12">

                <div class="row row-card-no-pd">

                    <!-- KASA -->
                    <div class="col-md-4">
                        <div class="card">
                            <div class="card-body">

                                <p class="fw-bold mt-1">Kasadaki Toplam Tutar</p>
                                <h3 id="totalBalance">Yükleniyor...</h3>

                                <hr>

                                <p class="fw-bold mt-1">Toplam Sipariş</p>
                                <h4 id="orderCount">0</h4>

                                <hr>

                                <p class="fw-bold mt-1">Toplam Ürün</p>
                                <h4 id="productCount">0</h4>

                                <a href="/Order/CreateOrder/" class="btn btn-primary btn-full text-left mt-3 mb-3">
                                    <i class="la la-plus"></i> Yeni Sipariş
                                </a>

                            </div>

                            <div class="card-footer">
                                <ul class="nav">

                                    <li class="nav-item">
                                        <a class="btn btn-default btn-link" href="/Order/Index/">
                                            <i class="la la-history"></i> Siparişler
                                        </a>
                                    </li>

                                    <li class="nav-item ml-auto">
                                        <a class="btn btn-default btn-link" href="/ProgressBar/Index/">
                                            <i class="la la-refresh"></i> Sayfayı Yenile
                                        </a>
                                    </li>

                                </ul>
                            </div>
                        </div>
                    </div>


                    <!-- PROGRESS -->
                    <div class="col-md-5">

                        <div class="card">
                            <div class="card-body">

                                <div class="progress-card" id="totalMenuTableCountProgress"></div>

                                <div class="progress-card" id="averageProductPrice"></div>

                                <div class="progress-card" id="productCountByCategoryNameHamburger"></div>

                                <div class="progress-card" id="productCountByCategoryNameDrink"></div>

                                <div class="progress-card" id="orderCount"></div>

                                <div class="progress-card" id="productCount"></div>

                                <div class="progress-card" id="activeCategoryCount"></div>

                                <div class="progress-card" id="passiveCategoryCount"></div>

                            </div>
                        </div>

                    </div>


                    <!-- CANLI İSTATİSTİK -->
                    <div class="col-md-3">

                        <div class="card card-stats">

                            <div class="card-body">

                                <p class="fw-bold mt-1">Anlık İstatistikler</p>


                                <div class="row">

                                    <div class="col-5">
                                        <div class="icon-big text-center icon-warning">
                                            <i class="la la-pie-chart text-warning"></i>
                                        </div>
                                    </div>

                                    <div class="col-7 d-flex align-items-center">
                                        <div class="numbers">
                                            <p class="card-category">Aktif Siparişler</p>
                                            <h4 class="card-title" id="activeOrderCount">0</h4>
                                        </div>
                                    </div>

                                </div>


                                <hr>


                                <div class="row">

                                    <div class="col-5">
                                        <div class="icon-big text-center">
                                            <i class="la la-heart-o text-primary"></i>
                                        </div>
                                    </div>

                                    <div class="col-7 d-flex align-items-center">
                                        <div class="numbers">
                                            <p class="card-category">Masa Sayısı</p>
                                            <h4 class="card-title" id="tableCount">0</h4>
                                        </div>
                                    </div>

                                </div>


                                <hr>


                                <div class="row">

                                    <div class="col-5">
                                        <div class="icon-big text-center">
                                            <i class="la la-list text-success"></i>
                                        </div>
                                    </div>

                                    <div class="col-7 d-flex align-items-center">
                                        <div class="numbers">
                                            <p class="card-category">Aktif Kategori</p>
                                            <h4 class="card-title" id="activeCategoryCount">14</h4>
                                        </div>
                                    </div>

                                </div>


                                <hr>


                                <div class="row">

                                    <div class="col-5">
                                        <div class="icon-big text-center">
                                            <i class="la la-ban text-danger"></i>
                                        </div>
                                    </div>

                                    <div class="col-7 d-flex align-items-center">
                                        <div class="numbers">
                                            <p class="card-category">Pasif Kategori</p>
                                            <h4 class="card-title" id="passiveCategoryCount">0</h4>
                                        </div>
                                    </div>

                                </div>


                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>
</div>


<script>
    $(document).ready(() => {
    ProgressHub.init("@ViewBag.HubUrl");
    });
</script>