@model SocialMediaViewModel
@{
	ViewData["Title"] = "CreateSocialMedia";
	Layout = "~/Views/AdminLayout/Index.cshtml";
}
<div class="content">
	<div class="container-fluid">
		<h4 class="page-title">Sosyal Medya İşlemleri</h4>
		<div class="row">
			<div class="col-md-12">
				<form asp-action="CreateSocialMedia" method="post">
					<div class="card">
						<div class="card-header">
							<div class="card-title">Yeni Sosyal Medya Girişi</div>
						</div>
						<div class="card-body">
							<div class="form-group">
								<label asp-for="Title">Başlık Giriniz</label>
								<input type="text" class="form-control" asp-for="Title">
								<span asp-validation-for="Title" class="text-danger"></span>
							</div>
							<div class="form-group">
								<label asp-for="Icon">İkon Giriniz</label>
								<input type="text" class="form-control" asp-for="Icon">
								<span asp-validation-for="Icon" class="text-danger"></span>
							</div>
							<div class="form-group">
								<label asp-for="Url">Link Giriniz</label>
								<input type="text" class="form-control" asp-for="Url">
								<span asp-validation-for="Url" class="text-danger"></span>
							</div>
						</div>
						<div class="card-action">
							<button type="submit" class="btn btn-primary">Sosyal Medya Hesabı Ekle</button>
						</div>
					</div>
				</form>
			</div>
		</div>
	</div>
</div>