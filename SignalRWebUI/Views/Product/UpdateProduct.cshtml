@model UpdateProductViewModel
@{
	ViewData["Title"] = "UpdateProduct";
	Layout = "~/Views/AdminLayout/Index.cshtml";
}
<div class="content">
	<div class="container-fluid">
		<h4 class="page-title">Ürün İşlemleri</h4>
		<div class="row">
			<div class="col-md-12">
				<form asp-action="UpdateProduct" asp-route-id="@Model.ProductID" method="post">
					<div class="card">
						<div class="card-header">
							<div class="card-title">Ürün Güncelleme Sayfası</div>
						</div>
						<div class="card-body">
							<div class="form-group">
								<Label for="ProductName">Ürün Adını Giriniz</label>
								<input type="text" class="form-control" placeholder="Ürün Adı Giriniz" asp-for="ProductName">
								<span asp-validation-for="ProductName" class="text-danger"></span>
							</div>
							<div class="form-group">
								<Label for="Price">Ürün Fiyatını Giriniz</label>
								<input type="number" step="0.01" class="form-control" placeholder="Ürün Fiyatını Giriniz" asp-for="Price">
								<span asp-validation-for="Price" class="text-danger"></span>
							</div>
							<div class="form-group">
								<Label for="ImageUrl">Ürün Görselini Giriniz</label>
								<input type="text" class="form-control" placeholder="Ürün Görselini Giriniz" asp-for="ImageUrl">
								<span asp-validation-for="ImageUrl" class="text-danger"></span>
							</div>
							<div class="form-group">
								<label for="categoryId">Ürün Kategorisini Giriniz</label>
								<select asp-for="CategoryID" asp-items="Model.CategoryList" class="form-control">
									<option value="">Kategori Seçiniz</option>
								</select>
								<span asp-validation-for="CategoryID" class="text-danger"></span>
							</div>
							<div class="form-group">
								<Label for="Description">Ürün Açıklamasını Giriniz</label>
								<textarea class="form-control" placeholder="Ürün Açıklamasını Giriniz" rows="4" asp-for="Description"></textarea>
								<span asp-validation-for="Description" class="text-danger"></span>
							</div>
						</div>
						<div class="card-action">
							<button type="submit" class="btn btn-primary">Ürünü Güncelle</button>
						</div>
					</div>
				</form>
			</div>
		</div>
	</div>
</div>