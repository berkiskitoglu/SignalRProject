@model NotificationViewModel
@{
	ViewData["Title"] = "CreateNotification";
	Layout = "~/Views/AdminLayout/Index.cshtml";
}
<div class="content">
	<div class="container-fluid">
		<h4 class="page-title">Bildirim İşlemleri</h4>
		<div class="row">
			<div class="col-md-12">
				<form asp-action="CreateNotification" method="post">
					<div class="card">
						<div class="card-header">
							<div class="card-title">Yeni Bildirim Girişi</div>
						</div>
						<div class="card-body">
							<div class="form-group">
								<Label for="Type">Bildirim Türü</label>
								<input type="text" class="form-control" asp-for="Type">
								<span asp-validation-for="Type" class="text-danger"></span>
							</div>
							<div class="form-group">
								<Label for="Icon">Bildirim İkon</label>
								<input type="text" class="form-control" asp-for="Icon">
								<span asp-validation-for="Icon" class="text-danger"></span>
							</div>
							<div class="form-group">
								<Label for="Description">Açıklamayı Giriniz</label>
								<textarea rows="5" class="form-control" asp-for="Description"></textarea>
								<span asp-validation-for="Description" class="text-danger"></span>
							</div>
						</div>
						<div class="card-action">
							<button type="submit" class="btn btn-primary">Bildirim Bilgisini Ekle</button>
						</div>
					</div>
				</form>
			</div>
		</div>
	</div>
</div>