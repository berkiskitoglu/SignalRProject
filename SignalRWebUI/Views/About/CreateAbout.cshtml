@model CreateAboutDto
@{
	ViewData["Title"] = "CreateAbout";
	Layout = "~/Views/AdminLayout/Index.cshtml";
}
<div class="content">
	<div class="container-fluid">
		<h4 class="page-title">Yeni Hakkımızda Yazı Girişi</h4>
		<div class="row">
			<div class="col-md-12">
				<form asp-action="CreateAbout" method="post">
					<div class="card">
						<div class="card-header">
							<div class="card-title">Yeni Hakkımda Girişi</div>
						</div>
						<div class="card-body">
							<div class="form-group">
								<Label for="Title">Başlığı Giriniz</label>
								<input type="text" class="form-control" asp-for="Title">
								<span asp-validation-for="Title" class="text-danger"></span>
							</div>
							<div class="form-group">
								<Label for="ImageUrl">Görsel Url'ini Giriniz</label>
								<input type="text" class="form-control" asp-for="ImageUrl">
								<span asp-validation-for="ImageUrl" class="text-danger"></span>
							</div>
							<div class="form-group">
								<Label for="Description">Açıklamayı Giriniz</label>
								<textarea rows="5" class="form-control" asp-for="Description"></textarea>
								<span asp-validation-for="Description" class="text-danger"></span>
							</div>
						</div>
						<div class="card-action">
							<button type="submit" class="btn btn-primary">Hakkımda Bilgisini Ekle</button>
						</div>
					</div>
				</form>
			</div>
		</div>
	</div>
</div>